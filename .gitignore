# Built outputs
/build
/app/build

# Gradle cache (but NOT wrapper!)
.gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# IDE
.idea/
*.iml
.DS_Store

# Local config (generated on each machine)
local.properties

# APK/AAB outputs
*.apk
*.ap_
*.aab

# NDK / CMake build artefacts
.cxx/
app/.cxx/

# Submodule build artefacts (сами субмодули отслеживаются через .gitmodules)
app/src/main/jni/ciadpi/build/
app/src/main/jni/tun2socks/build/

# Keystore (никогда не коммитить пароль от подписи)
*.keystore
*.jks

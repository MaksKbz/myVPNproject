# Built outputs
/build
/app/build

# Gradle cache (but NOT wrapper!)
.gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# IDE
.idea/
*.iml
.DS_Store

# Local config (generated on each machine)
local.properties

# APK/AAB outputs
*.apk
*.ap_
*.aab

# NDK / CMake build artefacts
.cxx/
app/.cxx/
*.o
*.a
*.so

# byedpi/badvpn — вендорены как обычные файлы (не submodule), но на всякий
# случай игнорируем случайные build-директории внутри них
app/src/main/jni/byedpi/build/
app/src/main/jni/badvpn/build/

# Keystore (никогда не коммитить пароль от подписи)
*.keystore
*.jks
